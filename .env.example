# Copy to .env for LOCAL runs only. On GitHub Actions these come from repo
# secrets (DIGEST_MATTERS_EMAIL / DIGEST_MATTERS_PASSWORD), not this file.

# --- Account (use a SEPARATE account per environment) ---
MATTERS_EMAIL=your-account@example.com
MATTERS_PASSWORD=your-password

# --- Environment (omit both for PRODUCTION) ---
# Production (default): matters.town
#   MATTERS_GRAPHQL_ENDPOINT=https://server.matters.news/graphql
#   MATTERS_SITE=https://matters.town
# Test / staging: matters.icu  (separate database — register a test account there)
#   MATTERS_GRAPHQL_ENDPOINT=https://server.matters.icu/graphql
#   MATTERS_SITE=https://matters.icu

# DRY_RUN=true   # uncomment to compose without posting
